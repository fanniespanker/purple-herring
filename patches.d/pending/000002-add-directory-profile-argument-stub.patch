diff --git a/scripts/apply-patches.sh b/scripts/apply-patches.sh
--- a/scripts/apply-patches.sh
+++ b/scripts/apply-patches.sh
@@ -6,6 +6,7 @@ MODE="--check"
 WORKDIR=""
 CONFIG_FILE=""
 DIRECTORY_PROFILE_FILE=""
+DIRECTORY_PROFILE=""
 GENERATE_CONFIG=0
 FORCE_CONFIG=0
 CREATE_NOTES=1
@@ -68,6 +69,7 @@ Config/workspace:
 Directory/checklist options:
   --patch-root DIR        set patch queue root; implies conventional child paths unless overridden
   --directory-profile-file FILE  accepted for future custom directory profiles; currently inert
+  --directory-profile NAME set directory profile: piscine, sane, or terse; aliases: fishy, ph, purple-herring
   --pending-dir DIR       set pending patch directory
   --applied-dir DIR       set applied patch directory
   --failed-dir DIR        set failed patch directory
@@ -86,6 +88,20 @@ USAGE
 
 die() { echo "error: $*" >&2; exit 1; }
 
+normalize_directory_profile() {
+  case "$1" in
+    "") echo "" ;;
+    piscine|fishy|ph|purple-herring|purple_herring) echo "piscine" ;;
+    sane) echo "sane" ;;
+    terse) echo "terse" ;;
+    *) die "unsupported directory profile: $1" ;;
+  esac
+}
+
 parse_args() {
   while [[ "$#" -gt 0 ]]; do
     case "$1" in
@@ -100,6 +116,7 @@ parse_args() {
       --fallback-tsv) FORCE_TSV=1; CHECKLIST_FORMAT="tsv" ;;
       --patch-root) shift; [[ "$#" -gt 0 ]] || die "--patch-root requires a directory"; PATCH_ROOT="$1"; CLI_PATCH_ROOT=1 ;;
       --directory-profile-file) shift; [[ "$#" -gt 0 ]] || die "--directory-profile-file requires a path"; DIRECTORY_PROFILE_FILE="$1" ;;
+      --directory-profile) shift; [[ "$#" -gt 0 ]] || die "--directory-profile requires a profile name"; DIRECTORY_PROFILE="$(normalize_directory_profile "$1")" ;;
       --pending-dir|--pending) shift; [[ "$#" -gt 0 ]] || die "--pending-dir requires a directory"; PENDING_DIR="$1"; CLI_PENDING_DIR=1 ;;
       --applied-dir|--applied) shift; [[ "$#" -gt 0 ]] || die "--applied-dir requires a directory"; APPLIED_DIR="$1"; CLI_APPLIED_DIR=1 ;;
       --failed-dir|--failed) shift; [[ "$#" -gt 0 ]] || die "--failed-dir requires a directory"; FAILED_DIR="$1"; CLI_FAILED_DIR=1 ;;
